{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Solver Input Schema",
  "type": "object",
  "required": [
    "grid",
    "fluid_properties",
    "initial_conditions",
    "simulation_parameters",
    "boundary_conditions",
    "mask",
    "external_forces",
    "domain_configuration"
  ],
  "properties": {
    "domain_configuration": {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "INTERNAL",
            "EXTERNAL"
          ],
          "description": "INTERNAL: Pressure-driven pipe flow. EXTERNAL: Far-field aerodynamics."
        },
        "reference_velocity": {
          "type": "number",
          "description": "Optional reference velocity for far-field calculations."
        }
      }
    },
    "grid": {
      "type": "object",
      "required": [
        "x_min",
        "x_max",
        "y_min",
        "y_max",
        "z_min",
        "z_max",
        "nx",
        "ny",
        "nz"
      ],
      "properties": {
        "x_min": {
          "type": "number",
          "description": "Physical coordinate of the domain start in X."
        },
        "x_max": {
          "type": "number",
          "description": "Physical coordinate of the domain end in X."
        },
        "y_min": {
          "type": "number",
          "description": "Physical coordinate of the domain start in Y."
        },
        "y_max": {
          "type": "number",
          "description": "Physical coordinate of the domain end in Y."
        },
        "z_min": {
          "type": "number",
          "description": "Physical coordinate of the domain start in Z."
        },
        "z_max": {
          "type": "number",
          "description": "Physical coordinate of the domain end in Z."
        },
        "nx": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of discrete computational cells along the X-axis."
        },
        "ny": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of discrete computational cells along the Y-axis."
        },
        "nz": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of discrete computational cells along the Z-axis."
        }
      }
    },
    "fluid_properties": {
      "type": "object",
      "required": [
        "density",
        "viscosity"
      ],
      "properties": {
        "density": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "viscosity": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "initial_conditions": {
      "type": "object",
      "required": [
        "velocity",
        "pressure"
      ],
      "properties": {
        "velocity": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "minItems": 3,
          "maxItems": 3
        },
        "pressure": {
          "type": "number"
        }
      }
    },
    "simulation_parameters": {
      "type": "object",
      "required": [
        "time_step",
        "total_time",
        "output_interval"
      ],
      "properties": {
        "time_step": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "total_time": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "output_interval": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "boundary_conditions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "location",
          "type"
        ],
        "properties": {
          "location": {
            "type": "string",
            "enum": [
              "x_min",
              "x_max",
              "y_min",
              "y_max",
              "z_min",
              "z_max",
              "wall"
            ]
          },
          "type": {
            "type": "string",
            "enum": [
              "no-slip",
              "free-slip",
              "inflow",
              "outflow",
              "pressure"
            ]
          },
          "values": {
            "type": "object",
            "properties": {
              "u": {
                "type": "number"
              },
              "v": {
                "type": "number"
              },
              "w": {
                "type": "number"
              },
              "p": {
                "type": "number"
              }
            }
          }
        }
      }
    },
    "mask": {
      "type": "array",
      "description": "Flat mask of length nx*ny*nz using canonical flattening: i + nx*(j + ny*k). Values: 1 = fluid, 0 = solid, -1 = boundary-fluid.",
      "items": {
        "type": "integer",
        "enum": [
          -1,
          0,
          1
        ]
      }
    },
    "external_forces": {
      "type": "object",
      "required": [
        "force_vector"
      ],
      "properties": {
        "force_vector": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "minItems": 3,
          "maxItems": 3
        }
      }
    }
  }
}